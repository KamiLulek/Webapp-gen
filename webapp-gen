#!/bin/bash
# webapp-gen — generator appek webowych (chromium --app) jako osobne procesy
# Komendy:
#   webapp-gen              -> interaktywne menu
#   webapp-gen -list        -> lista zainstalowanych
#   webapp-gen -remove <nazwa> -> usunięcie appki
#
# Uwaga: skrypt NIE wymaga uruchamiania przez sudo. Root jest potrzebny tylko
# do zapisu w /usr/local/bin/webapp-list — w tym momencie skrypt sam odpala
# pkexec i wyskakuje graficzne okienko na hasło. Reszta (ikony, .desktop)
# leci jako zwykły user.

set -e

WRAPPER_BASE="/usr/local/bin/webapp-list"
USER_HOME="${SUDO_USER:+/home/$SUDO_USER}"
USER_HOME="${USER_HOME:-$HOME}"
DESKTOP_DIR="${USER_HOME}/.local/share/applications"
ICON_DIR="${USER_HOME}/.local/share/icons/webapp-ico"

need_pkexec() {
    if ! command -v pkexec &>/dev/null; then
        echo "Brak pkexec (polkit). Zainstaluj: sudo pacman -S polkit"
        exit 1
    fi
}

# Zapisuje wrapper + cfg w /usr/local/bin/webapp-list/<nazwa>/ przez pkexec.
write_root_files() {
    local NAZWA="$1" WRAPPER_CONTENT="$2" CFG_CONTENT="$3"
    local APP_DIR="${WRAPPER_BASE}/${NAZWA}"

    local TMP_WRAPPER TMP_CFG
    TMP_WRAPPER=$(mktemp)
    TMP_CFG=$(mktemp)
    printf '%s' "$WRAPPER_CONTENT" > "$TMP_WRAPPER"
    printf '%s' "$CFG_CONTENT" > "$TMP_CFG"

    need_pkexec
    pkexec bash -c '
        set -e
        mkdir -p "$1"
        install -m 755 "$2" "$1/$3-app"
        install -m 644 "$4" "$1/$3.cfg"
    ' _ "$APP_DIR" "$TMP_WRAPPER" "$NAZWA" "$TMP_CFG"

    rm -f "$TMP_WRAPPER" "$TMP_CFG"
}

write_files() {
    local NAZWA="$1" URL="$2" ICON_LINE="$3" FLAGS="$4"
    local APP_DIR="${WRAPPER_BASE}/${NAZWA}"
    local WRAPPER="${APP_DIR}/${NAZWA}-app"
    local CFG="${APP_DIR}/${NAZWA}.cfg"
    local DESKTOP_FILE="${DESKTOP_DIR}/${NAZWA}.desktop"

    mkdir -p "$DESKTOP_DIR" "$ICON_DIR"

    local CFG_CONTENT WRAPPER_CONTENT
    CFG_CONTENT=$(cat << EOF
NAZWA="${NAZWA}"
URL="${URL}"
ICON="${ICON_LINE}"
FLAGS="${FLAGS}"
EOF
)
    WRAPPER_CONTENT=$(cat << EOF
#!/bin/bash
source "${CFG}"
chromium --class=\${NAZWA} \${FLAGS} \\
         --user-data-dir=${USER_HOME}/.config/\${NAZWA}-app \\
         --app=\${URL}
EOF
)

    write_root_files "$NAZWA" "$WRAPPER_CONTENT" "$CFG_CONTENT"

    tee "$DESKTOP_FILE" > /dev/null << EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=${NAZWA}
Comment=${NAZWA} webapp
Exec=${WRAPPER}
Icon=${ICON_LINE:-applications-internet}
Categories=Network;GTK;
Terminal=false
StartupNotify=true
StartupWMClass=${NAZWA}
EOF
    chmod +x "$DESKTOP_FILE"
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true

    echo "Gotowe: ${NAZWA}"
    echo "  Folder:   ${APP_DIR}"
    echo "  Wrapper:  ${WRAPPER}"
    echo "  Cfg:      ${CFG}"
    echo "  Desktop:  ${DESKTOP_FILE}"
}

ask_flags() {
    local flags=()

    # Flaga 1
    read -p "Wyłącz tłumacz i podpowiedzi Google (--disable-features=Translate,OptimizationGuide) [Y/n]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]] || [[ -z "$answer" ]]; then
        flags+=("--disable-features=Translate,OptimizationGuide")
    fi

    # Flaga 2
    read -p "Wyłącz zbędny ruch w tle (--disable-background-networking) [Y/n]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]] || [[ -z "$answer" ]]; then
        flags+=("--disable-background-networking")
    fi

    # Flaga 3
    read -p "Wyłącz rozszerzenia chromium (--disable-extensions) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--disable-extensions")
    fi

    # Flaga 4
    read -p "Wyłącz synchronizację kont Google (--disable-sync) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--disable-sync")
    fi

    # Flaga 5
    read -p "Wyłącz akcelerację GPU (--disable-gpu) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--disable-gpu")
    fi

    # Flaga 6
    read -p "Tryb incognito za każdym razem (--incognito) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--incognito")
    fi

    # Flaga 7
    read -p "Startuj zmaksymalizowane okno (--start-maximized) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--start-maximized")
    fi

    # Zwróć tylko flagi jako jeden string
    echo "${flags[@]}"
}

cmd_install() {
    echo ""
    echo "=== Instalacja nowej appki webowej ==="
    echo ""

    read -p "Nazwa (bez spacji): " NAZWA
    NAZWA=$(echo "$NAZWA" | tr -d ' ')

    if [[ -z "$NAZWA" ]]; then
        echo "Błąd: Nazwa nie może być pusta!"
        return 1
    fi

    if [[ -d "${WRAPPER_BASE}/${NAZWA}" ]]; then
        echo "Błąd: Appka '${NAZWA}' już istnieje!"
        return 1
    fi

    read -p "URL: " URL
    if [[ -z "$URL" ]]; then
        echo "Błąd: URL nie może być pusty!"
        return 1
    fi

    # Flagi
    FLAGS=$(ask_flags)
    echo ""
    echo "Wybrane flagi: $FLAGS"
    echo ""

    # Ikona
    echo "Podaj ścieżkę do ikony (ENTER = brak):"
    read -p "> " ICON_SRC

    local ICON_LINE=""
    if [[ -n "$ICON_SRC" && -f "$ICON_SRC" ]]; then
        local EXT="${ICON_SRC##*.}"
        local ICON_DEST="${ICON_DIR}/${NAZWA}.${EXT}"
        cp "$ICON_SRC" "$ICON_DEST"
        ICON_LINE="$ICON_DEST"
        echo "Ikona skopiowana: $ICON_LINE"
    elif [[ -n "$ICON_SRC" ]]; then
        echo "Ostrzeżenie: Plik '$ICON_SRC' nie istnieje. Pomijam ikonę."
    fi

    echo ""
    write_files "$NAZWA" "$URL" "$ICON_LINE" "$FLAGS"
}

cmd_list() {
    if [[ ! -d "$WRAPPER_BASE" ]] || [[ -z "$(find "$WRAPPER_BASE" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)" ]]; then
        echo "Brak zainstalowanych appek."
        return 0
    fi

    echo ""
    echo "=== Zainstalowane webappki ==="
    echo ""

    local i=1
    for dir in "$WRAPPER_BASE"/*/; do
        local nazwa_dir
        nazwa_dir=$(basename "$dir")
        local cfg="${dir}${nazwa_dir}.cfg"

        if [[ -f "$cfg" ]]; then
            source "$cfg"
            echo "$i. ${NAZWA}"
            echo "   URL:   ${URL}"
            echo "   Flagi: ${FLAGS}"
            echo ""
            ((i++))
        fi
    done
}

cmd_remove() {
    echo ""
    echo "=== Usuwanie appki ==="
    echo ""

    # Pokaż listę
    local apps=()
    local i=1
    for dir in "$WRAPPER_BASE"/*/; do
        local nazwa_dir
        nazwa_dir=$(basename "$dir")
        local cfg="${dir}${nazwa_dir}.cfg"

        if [[ -f "$cfg" ]]; then
            source "$cfg"
            apps+=("$NAZWA")
            echo "$i. $NAZWA"
            ((i++))
        fi
    done

    if [[ ${#apps[@]} -eq 0 ]]; then
        echo "Brak appek do usunięcia."
        return 0
    fi

    echo ""
    read -p "Podaj numer appki do usunięcia: " num

    if [[ "$num" =~ ^[0-9]+$ ]] && [[ "$num" -ge 1 ]] && [[ "$num" -le ${#apps[@]} ]]; then
        local NAZWA="${apps[$((num-1))]}"
        local APP_DIR="${WRAPPER_BASE}/${NAZWA}"

        echo "Usuwanie: $NAZWA"

        if [[ -d "$APP_DIR" ]]; then
            need_pkexec
            pkexec bash -c 'rm -rf "$1"' _ "$APP_DIR"
        fi

        rm -f "${DESKTOP_DIR}/${NAZWA}.desktop"
        rm -f "${ICON_DIR}/${NAZWA}".*
        update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true

        echo "Usunięto: ${NAZWA}"
    else
        echo "Błędny numer!"
        return 1
    fi
}

cmd_edit() {
    echo ""
    echo "=== Edycja istniejącej appki ==="
    echo ""

    # Pokaż listę
    local apps=()
    local i=1
    for dir in "$WRAPPER_BASE"/*/; do
        local nazwa_dir
        nazwa_dir=$(basename "$dir")
        local cfg="${dir}${nazwa_dir}.cfg"

        if [[ -f "$cfg" ]]; then
            source "$cfg"
            apps+=("$NAZWA")
            echo "$i. $NAZWA"
            ((i++))
        fi
    done

    if [[ ${#apps[@]} -eq 0 ]]; then
        echo "Brak appek do edycji."
        return 0
    fi

    echo ""
    read -p "Podaj numer appki do edycji: " num

    if [[ ! "$num" =~ ^[0-9]+$ ]] || [[ "$num" -lt 1 ]] || [[ "$num" -gt ${#apps[@]} ]]; then
        echo "Błędny numer!"
        return 1
    fi

    local NAZWA="${apps[$((num-1))]}"
    local CFG="${WRAPPER_BASE}/${NAZWA}/${NAZWA}.cfg"
    source "$CFG"

    echo ""
    echo "Edycja: $NAZWA"
    echo "Obecny URL: $URL"
    echo ""

    read -p "Nowy URL (ENTER = zostaw obecny): " NEW_URL
    [[ -z "$NEW_URL" ]] && NEW_URL="$URL"

    echo ""
    echo "Obecne flagi: $FLAGS"
    echo ""

    # Pobierz nowe flagi
    FLAGS=$(ask_flags)

    echo ""
    echo "Podaj ścieżkę do nowej ikony (ENTER = zostaw obecną):"
    read -p "> " ICON_SRC

    local ICON_LINE="$ICON"
    if [[ -n "$ICON_SRC" && -f "$ICON_SRC" ]]; then
        local EXT="${ICON_SRC##*.}"
        local ICON_DEST="${ICON_DIR}/${NAZWA}.${EXT}"
        cp "$ICON_SRC" "$ICON_DEST"
        ICON_LINE="$ICON_DEST"
        echo "Ikona zaktualizowana: $ICON_LINE"
    elif [[ -n "$ICON_SRC" ]]; then
        echo "Ostrzeżenie: Plik '$ICON_SRC' nie istnieje. Zostawiam obecną ikonę."
    fi

    echo ""
    write_files "$NAZWA" "$NEW_URL" "$ICON_LINE" "$FLAGS"
    echo "Zaktualizowano: ${NAZWA}"
}

main_menu() {
    echo ""
    echo "=== webapp-gen ==="
    echo "1. Instaluj nową appkę"
    echo "2. Lista zainstalowanych"
    echo "3. Edytuj appkę"
    echo "4. Usuń appkę"
    echo "5. Wyjście"
    echo ""

    read -p "Wybierz opcję [1-5]: " choice

    case "$choice" in
        1) cmd_install ;;
        2) cmd_list ;;
        3) cmd_edit ;;
        4) cmd_remove ;;
        5) echo "Do widzenia!"; exit 0 ;;
        *) echo "Nieprawidłowa opcja!" ;;
    esac
}
case "$1" in
    -list) cmd_list ;;
    -remove) cmd_remove ;;
    -h|--help|help)
        echo "Użycie:"
        echo "  webapp-gen              -> interaktywne menu"
        echo "  webapp-gen -list        -> lista zainstalowanych"
        echo "  webapp-gen -remove      -> interaktywne usuwanie"
        ;;
    "")
        while true; do
            main_menu
            echo ""
            read -p "Naciśnij Enter aby kontynuować..."
        done
        ;;
    *)
        echo "Nieznana opcja: $1"
        echo "Użyj 'webapp-gen -h' dla pomocy."
        exit 1
        ;;
esac

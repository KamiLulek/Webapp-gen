    NAME="${NAME:-$NAZWA}"

    local NEW_URL
    printf "$(t edit_current_url)\n" "$URL"
    read -p "$(t edit_new_url)" NEW_URL
    [[ -z "$NEW_URL" ]] && NEW_URL="$URL"

    printf "$(t edit_current_flags)\n" "$FLAGS"
    local NEW_FLAGS
    NEW_FLAGS=$(ask_flags)

    # NOWA LOGIKA: ENTER=zostaw / n=nowe / c=usuń
    local NEW_CUSTOM
    NEW_CUSTOM=$(handle_custom_flags_edit "$CUSTOM_FLAGS")

    echo "$(t edit_new_icon)"
    local ICON_INPUT ICON_PATH
    read -p " > " ICON_INPUT

    local ICON_LINE="$ICON"
    if ICON_PATH=$(resolve_icon_path "$ICON_INPUT" "$DEFAULT_ICON_PATH"); then
        ICON_LINE=$(copy_icon_to_storage "$ICON_PATH" "$NAME")
        printf "$(t edit_icon_updated)\n" "$ICON_LINE"
    fi

    write_app_files "$NAME" "$NEW_URL" "$ICON_LINE" "$NEW_FLAGS" "$NEW_CUSTOM"
}

# ----------------
#          Usuwa konkretną apkę podaną z nazwy (z potwierdzeniem)      /       Removes a specific app specified by name (with confirmation)
# -----------------
remove_app_direct() {
    local NAME="$1"
    local confirm
    read -p "$(printf "$(t remove_confirm)" "$NAME")" confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        return 1
    fi
    rm -f "${WRAPPER_DIR}/${NAME}-app" "${APPS_CONFIG_DIR}/${NAME}.cfg" "${DESKTOP_DIR}/${NAME}.desktop" "${ICON_DIR}/${NAME}".*
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true
    printf "$(t remove_done)\n" "$NAME"
    return 0
}

# ----------------
#          Instaluje nową apkę - pyta o nazwę, URL, flagi i ikonę      /       Installs a new app - asks for name, URL, flags, and icon
# -----------------
cmd_install() {
    printf "\n$(t separator_up)"
    printf "\n$(t install_title)"
    printf "\n$(t separator_down)\n\n"
    local NAME URL FLAGS CUSTOM_FLAGS ICON_INPUT ICON_PATH ICON_LINE

    while true; do
        read -p "$(t install_name)" NAME
        NAME=$(echo "$NAME" | tr -d ' ')
        if [[ -z "$NAME" ]]; then
            echo "$(t install_name_error)"
        elif [[ ! "$NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then
            echo "$(t install_name_invalid)"
        elif [[ -f "${APPS_CONFIG_DIR}/${NAME}.cfg" ]] || [[ -f "${WRAPPER_DIR}/${NAME}-app" ]]; then
            printf "$(t install_exists)\n" "$NAME"
        else
            break
        fi
        local retry_choice
        read -n 1 -p "$(t install_retry_prompt)" retry_choice
        echo ""
        case "$retry_choice" in
            p|P) return 0 ;;
            q|Q) echo "$(t goodbye)"; exit 0 ;;
            *) : ;;
        esac
    done

    read -p "$(t install_url)" URL
    if [[ -z "$URL" ]]; then echo "$(t install_url_error)"; return 0; fi
    FLAGS=$(ask_flags)
    printf "\n$(t install_flags_choice)\n" "$FLAGS"
    read -p "$(t install_custom_flags)" CUSTOM_FLAGS
    echo ""
    echo "$(t install_icon_prompt)"
    read -p "$DEFAULT_ICON_PATH: " ICON_INPUT
    ICON_LINE=""
    if ICON_PATH=$(resolve_icon_path "$ICON_INPUT" "$DEFAULT_ICON_PATH"); then
        ICON_LINE=$(copy_icon_to_storage "$ICON_PATH" "$NAME")
        printf "$(t install_icon_copied)\n" "$ICON_LINE"
    fi
    write_app_files "$NAME" "$URL" "$ICON_LINE" "$FLAGS" "$CUSTOM_FLAGS"
}

# ----------------
#          Lista z widokiem szczegółów i akcjami e/r/p/q      /       List with details view and e/r/p/q actions
# -----------------
cmd_list() {
    while true; do
        get_all_apps
        if [[ ${#APPS[@]} -eq 0 ]]; then

            echo ""
            echo "$(t list_empty)"
            return 0
        fi

        clear
        printf "\n$(t separator_up)"
        printf "\n$(t list_title)"
        printf "\n$(t separator_down)\n\n"
        local i=1
        for app_name in "${APPS[@]}"; do
            echo " $i. $app_name"
            ((i++))
        done
        echo ""
        echo " ___________________ "
        printf "$(t key_p)"
        printf "\n$(t key_q)\n"
        echo ""

        local sel
        read -p "$(t list_select_prompt)" sel

        # powrót do menu głównego
        if [[ "$sel" == "p" ]] || [[ "$sel" == "P" ]]; then
            return 0
        fi
        if [[ "$sel" == "q" ]] || [[ "$sel" == "Q" ]]; then
            echo "$(t goodbye)"
            exit 0
        fi

        if [[ ! "$sel" =~ ^[0-9]+$ ]] || (( sel < 1 || sel > ${#APPS[@]} )); then
            echo "$(t edit_invalid)"
            sleep 1
            continue
        fi

        local SELECTED
        SELECTED=$(get_app_name_by_index "$sel")

        # pętla szczegółów wybranej appki
        while true; do
            clear
            show_app_details "$SELECTED"

            local action
            read -n 1 -p "$(t detail_prompt)" action
            echo ""

            case "$action" in
                e|E)
                    echo ""
                    edit_app_direct "$SELECTED"
                    echo ""
                    read -n 1 -p "$(t press_enter)" _
                    ;;
                r|R)
                    echo ""
                    if remove_app_direct "$SELECTED"; then
                        sleep 1
                        break # usuń -> wróć do listy
                    fi
                    ;;
                p|P)
                    break # powrót do listy
                    ;;
                q|Q)
                    echo "$(t goodbye)"
                    exit 0
                    ;;
                *)
                    echo "$(t menu_invalid)"
                    sleep 1
                    ;;
            esac
        done
    done
}

# ----------------
#          Lista CLI: sama lista bez okna wyboru      /       CLI List: list only, no selection window
# -----------------
cmd_list_plain() {
    get_all_apps
    if [[ ${#APPS[@]} -eq 0 ]]; then
        echo ""
        echo "$(t list_empty)"
        return 0
    fi
    printf "\n$(t separator_up)"
    printf "\n$(t list_title_cli)"
    printf "\n$(t separator_down)\n\n"
    local i=1
    for app_name in "${APPS[@]}"; do
        echo " $i. $app_name"
        ((i++))
    done
    echo ""
}

# ----------------
#          Zwraca numer wersji z pliku pod REPO_RAW_URL (bez pobierania całości do dysku)      /       Returns the version number from the file at REPO_RAW_URL (without saving it to disk)
# -----------------
get_remote_version() {
    local timeout="${1:-5}"
    curl -fsSL --max-time "$timeout" "$REPO_RAW_URL" 2>/dev/null \
        | grep -m1 -E '^[[:space:]]*VER=' \
        | sed -E 's/^[[:space:]]*VER="?([^"]*)"?.*/\1/'
}

# ----------------
#          Porównuje wersje (sort -V) - zwraca 0 jeśli $1 > $2      /       Compares versions (sort -V) - returns 0 if $1 > $2
# -----------------
version_gt() {
    [[ -z "$1" || -z "$2" ]] && return 1
    [[ "$1" == "$2" ]] && return 1
    [[ "$(printf '%s\n%s\n' "$1" "$2" | sort -V | tail -n1)" == "$1" ]]
}

# ----------------
#          Ciche sprawdzenie w tle (max raz na UPDATE_CHECK_INTERVAL) - pokazuje info w menu głównym      /       Silent background check (max once per UPDATE_CHECK_INTERVAL) - shows a notice in the main menu
# -----------------
maybe_notify_update() {
    command -v curl &>/dev/null || return 0
    local now last_check
    now=$(date +%s)
    if [[ -f "$UPDATE_CACHE_FILE" ]]; then
        last_check=$(cat "$UPDATE_CACHE_FILE" 2>/dev/null)
        if [[ "$last_check" =~ ^[0-9]+$ ]] && (( now - last_check < UPDATE_CHECK_INTERVAL )); then
            return 0
        fi
    fi
    local remote_ver
    remote_ver=$(get_remote_version 2)
    echo "$now" > "$UPDATE_CACHE_FILE" 2>/dev/null
    if version_gt "$remote_ver" "$VER"; then
        printf "$(t update_notice)\n\n" "$remote_ver"
    fi
}

# ----------------
#          Sprawdza i wykonuje aktualizację skryptu z GitHuba      /       Checks for and performs the script update from GitHub
# -----------------
cmd_update() {
    echo ""
    echo "$(t update_checking)"
    if ! command -v curl &>/dev/null; then
        echo "$(t update_no_curl)"
        return 1
    fi

    local remote_ver
    remote_ver=$(get_remote_version 10)
    date +%s > "$UPDATE_CACHE_FILE" 2>/dev/null

    if [[ -z "$remote_ver" ]]; then
        echo "$(t update_check_failed)"
        return 1
    fi

    if ! version_gt "$remote_ver" "$VER"; then
        printf "$(t update_uptodate)\n" "$VER"
        return 0
    fi

    printf "$(t update_available)\n" "$VER" "$remote_ver"
    local confirm
    read -p "$(t update_confirm)" confirm
    if [[ "$confirm" =~ ^[Nn]$ ]]; then
        echo "$(t update_cancelled)"
        return 0
    fi

    local script_path tmpfile
    script_path="$(readlink -f "$0")"
    tmpfile=$(mktemp)

    if curl -fsSL --max-time 20 "$REPO_RAW_URL" -o "$tmpfile" \
        && [[ -s "$tmpfile" ]] \
        && head -n1 "$tmpfile" | grep -q '^#!/bin/bash'; then
        chmod +x "$tmpfile"
        if [[ -w "$script_path" ]]; then
            mv "$tmpfile" "$script_path"
        else
            need_pkexec
            pkexec mv "$tmpfile" "$script_path"
        fi
        printf "$(t update_done)\n" "$remote_ver"
    else
        rm -f "$tmpfile"
        echo "$(t update_download_failed)"
        return 1
    fi
}

# ----------------
#          Edytuje globalną konfigurację - język i ścieżkę ikon      /       Edits global configuration - language and icon path
# -----------------
cmd_config() {
    clear
    printf "\n$(t separator_up)"
    printf "\n$(t config_title)"
    printf "\n$(t separator_down)\n\n"
    local new_lang new_path
    read -p "$(printf "$(t config_lang)" "$LANG_CHOICE")" new_lang
    [[ -n "$new_lang" ]] && LANG_CHOICE="$new_lang"
    read -p "$(printf "$(t config_icon_path)" "$DEFAULT_ICON_PATH")" new_path
    [[ -n "$new_path" ]] && DEFAULT_ICON_PATH="$new_path"
    save_config
    echo "$(t config_done)"
}

# ----------------
#          Wyświetla główne menu 1-4 i obsługuje wybór      /       Displays main menu 1-4 and handles selection
# -----------------
main_menu() {
    clear
    printf "\n$(t separator_up)"
    printf "\n$(t menu_title)"
    printf "\n$(t separator_down)\n\n"
    maybe_notify_update
    echo "$(t menu_install)"
    echo "$(t menu_list)"
    echo "$(t menu_config)"
    echo "$(t menu_exit)"
    echo ""
    local choice
    read -n 1 -p "$(t menu_prompt)" choice
    echo ""
    if [[ "$choice" == "q" ]] || [[ "$choice" == "Q" ]]; then
        echo "$(t goodbye)"
        exit 0
    fi
    case "$choice" in
        1) cmd_install ;;
        2) cmd_list ;;
        3) cmd_config ;;
        4) echo "$(t goodbye)"; exit 0 ;;
        *) echo "$(t menu_invalid)"; sleep 1 ;;
    esac
}

# ----------------
#          Główna pętla interaktywna      /       Main interactive loop
# -----------------
main_loop() {
    while true; do
        main_menu
        echo ""
        local input
        read -n 1 -p "$(t press_enter)" input
        echo ""
        if [[ "$input" == "q" ]] || [[ "$input" == "Q" ]]; then
            echo "$(t goodbye)"
            exit 0
        fi
    done
}

# ----------------
#          Obsługuje argumenty CLI      /       Handles CLI arguments
# -----------------
handle_cli_args() {
    case "$1" in
        -list) cmd_list_plain ;;
        -remove)
            get_all_apps
            [[ ${#APPS[@]} -eq 0 ]] && echo "$(t list_empty)" && return
            for i in "${!APPS[@]}"; do echo " $((i+1)). ${APPS[$i]}"; done
            read -p "$(t list_select_prompt)" sel
            if [[ "$sel" =~ ^[0-9]+$ ]]; then
                local n; n=$(get_app_name_by_index "$sel")
                [[ -n "$n" ]] && remove_app_direct "$n"
            fi
            ;;
        -edit)
            get_all_apps
            [[ ${#APPS[@]} -eq 0 ]] && echo "$(t list_empty)" && return
            for i in "${!APPS[@]}"; do echo ""; echo " $((i+1)). ${APPS[$i]}"; done
            read -p "$(t list_select_prompt)" sel
            if [[ "$sel" =~ ^[0-9]+$ ]]; then
                local n; n=$(get_app_name_by_index "$sel")
                [[ -n "$n" ]] && edit_app_direct "$n"
            fi
            ;;
        -config) cmd_config ;;
        -update) cmd_update ;;
        -info)
            local n="$2"
            if [[ -z "$n" ]] || [[ ! -f "${APPS_CONFIG_DIR}/${n}.cfg" ]]; then
                printf "$(t cli_app_not_found)\n" "$n"
                return 1
            fi
            show_app_info "$n"
            ;;
        -name-e)
            local n="$2"
            if [[ -z "$n" ]] || [[ ! -f "${APPS_CONFIG_DIR}/${n}.cfg" ]]; then
                printf "$(t cli_app_not_found)\n" "$n"
                return 1
            fi
            show_app_info "$n"
            edit_app_direct "$n"
            ;;
        -name-r)
            local n="$2"
            if [[ -z "$n" ]] || [[ ! -f "${APPS_CONFIG_DIR}/${n}.cfg" ]]; then
                printf "$(t cli_app_not_found)\n" "$n"
                return 1
            fi
            remove_app_direct "$n"
            ;;
        -h|--help|help)
            echo ""
            echo " $(t wag-usage)"
            echo "  webapp-gen                  ->" "$(t wag-h)"
            echo "  webapp-gen -list            ->" "$(t wag-h-list)"
            echo "  webapp-gen -edit            ->" "$(t wag-h-edit)"
            echo "  webapp-gen -remove          ->" "$(t wag-h-remove)"
            echo "  webapp-gen -info name       ->" "$(t wag-h-name-i)"
            echo "  webapp-gen -name-e name     ->" "$(t wag-h-name-e)"
            echo "  webapp-gen -name-r name     ->" "$(t wag-h-name-r)"
            echo "  webapp-gen -config          ->" "$(t wag-h-c)"
            echo "  webapp-gen -update          ->" "$(t wag-h-update)"
            echo "  webapp-gen -h               ->  Help menu"
            echo ""
            echo "  VERSION:                    ->" "$(t version_title)"
            echo ""
            ;;
        "") main_loop ;;
        *) echo " $(t help-unknow) $1"; echo " $(t help-info) "; exit 1 ;;
    esac
}

# ----------------
#          Punkt wejścia programu      /       Program entry point
# -----------------
main() {
    init_globals
    ensure_dirs
    load_lang
    handle_cli_args "$@"
}

main "$@"

need_pkexec() {
    if ! command -v pkexec &>/dev/null; then
        echo "Brak pkexec (polkit). Zainstaluj: sudo pacman -S polkit"
        exit 1
    fi
}

# Zapisuje wrapper + cfg w /usr/local/bin/webapp-list/<nazwa>/ przez pkexec.
write_root_files() {
    local NAZWA="$1" WRAPPER_CONTENT="$2" CFG_CONTENT="$3"
    local APP_DIR="${WRAPPER_BASE}/${NAZWA}"

    local TMP_WRAPPER TMP_CFG
    TMP_WRAPPER=$(mktemp)
    TMP_CFG=$(mktemp)
    printf '%s' "$WRAPPER_CONTENT" > "$TMP_WRAPPER"
    printf '%s' "$CFG_CONTENT" > "$TMP_CFG"

    need_pkexec
    pkexec bash -c '
        set -e
        mkdir -p "$1"
        install -m 755 "$2" "$1/$3-app"
        install -m 644 "$4" "$1/$3.cfg"
    ' _ "$APP_DIR" "$TMP_WRAPPER" "$NAZWA" "$TMP_CFG"

    rm -f "$TMP_WRAPPER" "$TMP_CFG"
}

write_files() {
    local NAZWA="$1" URL="$2" ICON_LINE="$3" FLAGS="$4"
    local APP_DIR="${WRAPPER_BASE}/${NAZWA}"
    local WRAPPER="${APP_DIR}/${NAZWA}-app"
    local CFG="${APP_DIR}/${NAZWA}.cfg"
    local DESKTOP_FILE="${DESKTOP_DIR}/${NAZWA}.desktop"

    mkdir -p "$DESKTOP_DIR" "$ICON_DIR"

    local CFG_CONTENT WRAPPER_CONTENT
    CFG_CONTENT=$(cat << EOF
NAZWA="${NAZWA}"
URL="${URL}"
ICON="${ICON_LINE}"
FLAGS="${FLAGS}"
EOF
)
    WRAPPER_CONTENT=$(cat << EOF
#!/bin/bash
source "${CFG}"
chromium --class=\${NAZWA} \${FLAGS} \\
         --user-data-dir=${USER_HOME}/.config/\${NAZWA}-app \\
         --app=\${URL}
EOF
)

    write_root_files "$NAZWA" "$WRAPPER_CONTENT" "$CFG_CONTENT"

    tee "$DESKTOP_FILE" > /dev/null << EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=${NAZWA}
Comment=${NAZWA} webapp
Exec=${WRAPPER}
Icon=${ICON_LINE:-applications-internet}
Categories=Network;GTK;
Terminal=false
StartupNotify=true
StartupWMClass=${NAZWA}
EOF
    chmod +x "$DESKTOP_FILE"
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true

    echo ""
    printf "$(t install_done)\n" "$NAZWA"
    echo "  Folder:   ${APP_DIR}"
    echo "  Wrapper:  ${WRAPPER}"
    echo "  Cfg:      ${CFG}"
    echo "  Desktop:  ${DESKTOP_FILE}"
}

ask_flags() {
    printf "\n$(t install_flags_title)\n\n"

    local flags=()

    read -p "Wyłącz tłumacz i podpowiedzi Google (--disable-features=Translate,OptimizationGuide) [Y/n]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]] || [[ -z "$answer" ]]; then
        flags+=("--disable-features=Translate,OptimizationGuide")
    fi

    read -p "Wyłącz zbędny ruch w tle (--disable-background-networking) [Y/n]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]] || [[ -z "$answer" ]]; then
        flags+=("--disable-background-networking")
    fi

    read -p "Wyłącz rozszerzenia chromium (--disable-extensions) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--disable-extensions")
    fi

    read -p "Wyłącz synchronizację kont Google (--disable-sync) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--disable-sync")
    fi

    read -p "Wyłącz akcelerację GPU (--disable-gpu) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--disable-gpu")
    fi

    read -p "Tryb incognito za każdym razem (--incognito) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--incognito")
    fi

    read -p "Startuj zmaksymalizowane okno (--start-maximized) [y/N]: " answer
    if [[ "$answer" =~ ^[Yy]$ ]]; then
        flags+=("--start-maximized")
    fi

    echo "${flags[@]}"
}

get_icon_path() {
    local prompt="$1"
    local default_path="$DEFAULT_ICON_PATH"

    echo ""
    echo "$prompt"
    echo "   (ENTER = brak, lub podaj nazwę pliku z domyślnego folderu: $default_path)"
    read -p "> " ICON_INPUT

    if [[ -z "$ICON_INPUT" ]]; then
        echo ""
        return 1
    fi

    # Sprawdź czy to pełna ścieżka
    if [[ -f "$ICON_INPUT" ]]; then
        echo "$ICON_INPUT"
        return 0
    fi

    # Sprawdź w domyślnym folderze
    if [[ -f "${default_path}/${ICON_INPUT}" ]]; then
        echo "${default_path}/${ICON_INPUT}"
        return 0
    fi

    # Nie znaleziono
    echo ""
    return 1
}

cmd_install() {
    printf "\n$(t install_title)\n\n"

    read -p "$(t install_name)" NAZWA
    NAZWA=$(echo "$NAZWA" | tr -d ' ')

    if [[ -z "$NAZWA" ]]; then
        echo "$(t install_name_error)"
        return 1
    fi

    if [[ -d "${WRAPPER_BASE}/${NAZWA}" ]]; then
        printf "$(t install_exists)\n" "$NAZWA"
        return 1
    fi

    read -p "$(t install_url)" URL
    if [[ -z "$URL" ]]; then
        echo "$(t install_url_error)"
        return 1
    fi

    FLAGS=$(ask_flags)
    printf "\n$(t install_flags_choice)\n" "$FLAGS"

    ICON_PATH=$(get_icon_path "$(t install_icon_prompt)")
    local ICON_LINE=""

    if [[ -n "$ICON_PATH" ]]; then
        local EXT="${ICON_PATH##*.}"
        local ICON_DEST="${ICON_DIR}/${NAZWA}.${EXT}"
        cp "$ICON_PATH" "$ICON_DEST"
        ICON_LINE="$ICON_DEST"
        printf "$(t install_icon_copied)\n" "$ICON_LINE"
    fi

    echo ""
    write_files "$NAZWA" "$URL" "$ICON_LINE" "$FLAGS"
}

cmd_list() {
    if [[ ! -d "$WRAPPER_BASE" ]] || [[ -z "$(find "$WRAPPER_BASE" -mindepth 1 -maxdepth 1 -type d 2>/dev/null)" ]]; then
        echo "$(t list_empty)"
        return 0
    fi

    printf "\n$(t list_title)\n\n"

    local i=1
    for dir in "$WRAPPER_BASE"/*/; do
        local nazwa_dir
        nazwa_dir=$(basename "$dir")
        local cfg="${dir}${nazwa_dir}.cfg"

        if [[ -f "$cfg" ]]; then
            source "$cfg"
            echo "$i. ${NAZWA}"
            echo "   URL:   ${URL}"
            echo "   Flagi: ${FLAGS}"
            echo ""
            ((i++))
        fi
    done
}

cmd_edit() {
    printf "\n$(t edit_title)\n\n"

    local apps=()
    local i=1
    for dir in "$WRAPPER_BASE"/*/; do
        local nazwa_dir
        nazwa_dir=$(basename "$dir")
        local cfg="${dir}${nazwa_dir}.cfg"

        if [[ -f "$cfg" ]]; then
            source "$cfg"
            apps+=("$NAZWA")
            echo "$i. $NAZWA"
            ((i++))
        fi
    done

    if [[ ${#apps[@]} -eq 0 ]]; then
        echo "$(t edit_empty)"
        return 0
    fi

    echo ""
    read -p "$(t edit_prompt)" num

    if [[ ! "$num" =~ ^[0-9]+$ ]] || [[ "$num" -lt 1 ]] || [[ "$num" -gt ${#apps[@]} ]]; then
        echo "$(t edit_invalid)"
        return 1
    fi

    local NAZWA="${apps[$((num-1))]}"
    local CFG="${WRAPPER_BASE}/${NAZWA}/${NAZWA}.cfg"
    source "$CFG"

    printf "\n$(t edit_info)\n" "$NAZWA"
    printf "$(t edit_current_url)\n" "$URL"
    echo ""

    read -p "$(t edit_new_url)" NEW_URL
    [[ -z "$NEW_URL" ]] && NEW_URL="$URL"

    printf "$(t edit_current_flags)\n" "$FLAGS"
    echo ""

    FLAGS=$(ask_flags)

    ICON_PATH=$(get_icon_path "$(t edit_new_icon)")
    local ICON_LINE="$ICON"

    if [[ -n "$ICON_PATH" ]]; then
        local EXT="${ICON_PATH##*.}"
        local ICON_DEST="${ICON_DIR}/${NAZWA}.${EXT}"
        cp "$ICON_PATH" "$ICON_DEST"
        ICON_LINE="$ICON_DEST"
        printf "$(t edit_icon_updated)\n" "$ICON_LINE"
    fi

    echo ""
    write_files "$NAZWA" "$NEW_URL" "$ICON_LINE" "$FLAGS"
}

cmd_remove() {
    printf "\n$(t remove_title)\n\n"

    local apps=()
    local i=1
    for dir in "$WRAPPER_BASE"/*/; do
        local nazwa_dir
        nazwa_dir=$(basename "$dir")
        local cfg="${dir}${nazwa_dir}.cfg"

        if [[ -f "$cfg" ]]; then
            source "$cfg"
            apps+=("$NAZWA")
            echo "$i. $NAZWA"
            ((i++))
        fi
    done

    if [[ ${#apps[@]} -eq 0 ]]; then
        echo "$(t remove_empty)"
        return 0
    fi

    echo ""
    read -p "$(t remove_prompt)" num

    if [[ ! "$num" =~ ^[0-9]+$ ]] || [[ "$num" -lt 1 ]] || [[ "$num" -gt ${#apps[@]} ]]; then
        echo "$(t remove_invalid)"
        return 1
    fi

    local NAZWA="${apps[$((num-1))]}"
    local APP_DIR="${WRAPPER_BASE}/${NAZWA}"

    printf "$(t remove_confirm)\n" "$NAZWA"

    if [[ -d "$APP_DIR" ]]; then
        need_pkexec
        pkexec bash -c 'rm -rf "$1"' _ "$APP_DIR"
    fi

    rm -f "${DESKTOP_DIR}/${NAZWA}.desktop"
    rm -f "${ICON_DIR}/${NAZWA}".*
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true

    printf "$(t remove_done)\n" "$NAZWA"
}

cmd_config() {
    printf "\n$(t config_title)\n\n"

    read -p "$(printf "$(t config_lang)" "$LANG_CHOICE")" new_lang
    [[ -n "$new_lang" ]] && LANG_CHOICE="$new_lang"

    read -p "$(printf "$(t config_icon_path)" "$DEFAULT_ICON_PATH")" new_path
    [[ -n "$new_path" ]] && DEFAULT_ICON_PATH="$new_path"

    # Zapisz config
    cat > "$CONFIG_FILE" << EOF
# webapp-gen config
LANG_CHOICE="$LANG_CHOICE"
DEFAULT_ICON_PATH="$DEFAULT_ICON_PATH"
EOF

    echo "$(t config_done)"
}

main_menu() {
    printf "\n$(t menu_title)\n"
    echo "$(t menu_install)"
    echo "$(t menu_list)"
    echo "$(t menu_edit)"
    echo "$(t menu_config)"
    echo "$(t menu_remove)"
    echo "$(t menu_exit)"
    echo ""

    read -p "$(t menu_prompt)" choice

    case "$choice" in
        1) cmd_install ;;
        2) cmd_list ;;
        3) cmd_edit ;;
        4) cmd_config ;;
        5) cmd_remove ;;
        6) echo "$(t goodbye)"; exit 0 ;;
        *) echo "$(t menu_invalid)" ;;
    esac
}

# --- START ---
load_lang

case "$1" in
    -list) cmd_list ;;
    -remove) cmd_remove ;;
    -edit) cmd_edit ;;
    -config) cmd_config ;;
    -h|--help|help)
        echo "Użycie:"
        echo "  webapp-gen              -> interaktywne menu"
        echo "  webapp-gen -list        -> lista zainstalowanych"
        echo "  webapp-gen -edit        -> edytuj appkę"
        echo "  webapp-gen -remove      -> usuń appkę"
        echo "  webapp-gen -config      -> konfiguracja"
        ;;
    "")
        while true; do
            main_menu
            echo ""
            read -p "$(t press_enter)"
        done
        ;;
    *)
        echo "Nieznana opcja: $1"
        echo "Użyj 'webapp-gen -h' dla pomocy."
        exit 1
        ;;
esac

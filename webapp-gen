#!/bin/bash
# webapp-gen — generator appek webowych (chromium --app)
set -e

# ----------------
#          Inicjalizuje globalne ścieżki i zmienne
# -----------------
init_globals() {
    USER_HOME="$HOME"
    WRAPPER_DIR="${USER_HOME}/.local/bin/webapp-list"
    DESKTOP_DIR="${USER_HOME}/.local/share/applications"
    ICON_DIR="${USER_HOME}/.local/share/icons/webapp-ico"
    CONFIG_DIR="${USER_HOME}/.config/webapp-gen"
    CONFIG_FILE="${CONFIG_DIR}/config.cfg"
    APPS_CONFIG_DIR="${CONFIG_DIR}/apps"
    VERSION="0.9-alpha"
}

# ----------------
#          Tworzy wszystkie wymagane katalogi
# -----------------
ensure_dirs() {
    mkdir -p "$CONFIG_DIR" "$APPS_CONFIG_DIR" "$WRAPPER_DIR" "$DESKTOP_DIR" "$ICON_DIR"
}

# ----------------
#          Ładuje język i config, jeśli brak to odpala first_time_config
# -----------------
load_lang() {
    LANG_CHOICE="pl"
    DEFAULT_ICON_PATH="${USER_HOME}/Obrazy"
    ensure_dirs
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    else
        first_time_config
    fi
}

# ----------------
#          Pierwsze uruchomienie - wybór języka i domyślnej ścieżki ikon
# -----------------
first_time_config() {
    echo ""
    echo "╔════════════════════════════════════════╗"
    echo "║          webapp-gen - FIRST RUN        ║"
    echo "╚════════════════════════════════════════╝"
    echo ""
    echo "Select language / Wybierz język:"
    echo "  1. Polski"
    echo "  2. English"
    echo ""
    read -p "Choose / Wybierz [1-2]: " lang_choice
    case "$lang_choice" in
        2) LANG_CHOICE="en"; echo ""; echo "Selected: English" ;;
        *) LANG_CHOICE="pl"; echo ""; echo "Wybrano: Polski" ;;
    esac
    echo ""
    if [[ "$LANG_CHOICE" == "en" ]]; then
        echo "Enter default path for icons:"
        echo "  (ENTER for default: ${USER_HOME})"
        read -p "Set path: " icon_path_input
    else
        echo "Podaj domyślną ścieżkę dla ikon:"
        echo "  (ENTER dla domyślnej: ${USER_HOME})"
        read -p "Ustaw ścieżkę: " icon_path_input
    fi
    [[ -n "$icon_path_input" ]] && DEFAULT_ICON_PATH="$icon_path_input"
    save_config
    echo ""
    if [[ "$LANG_CHOICE" == "en" ]]; then
        echo "Configuration saved to: $CONFIG_FILE"
    else
        echo "Konfiguracja zapisana w: $CONFIG_FILE"
    fi
    echo ""
    read -p "Press Enter to continue..."
}

# ----------------
#          Zapisuje aktualną konfigurację do pliku
# -----------------
save_config() {
    cat > "$CONFIG_FILE" << EOF
# webapp-gen config
LANG_CHOICE="$LANG_CHOICE"
DEFAULT_ICON_PATH="$DEFAULT_ICON_PATH"
EOF
}


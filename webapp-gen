#!/bin/bash
# webapp-gen — generator appek webowych (chromium --app)

set -e

WRAPPER_BASE="/usr/local/bin/webapp-list"
USER_HOME="${SUDO_USER:+/home/$SUDO_USER}"
USER_HOME="${USER_HOME:-$HOME}"
DESKTOP_DIR="${USER_HOME}/.local/share/applications"
ICON_DIR="${USER_HOME}/.local/share/icons/webapp-ico"
CONFIG_DIR="${USER_HOME}/.config/webapp-gen"
CONFIG_FILE="${CONFIG_DIR}/config.cfg"


# --- Funkcje językowe ---
load_lang() {
    # Domyślne wartości
    LANG_CHOICE="pl"
    DEFAULT_ICON_PATH="${USER_HOME}/Obrazy"

    mkdir -p "$CONFIG_DIR"

    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    else
        first_time_config
    fi
}

first_time_config() {
    echo ""
    echo "╔════════════════════════════════════════╗"
    echo "║          webapp-gen - FIRST RUN       ║"
    echo "╚════════════════════════════════════════╝"
    echo ""
    echo "Select language / Wybierz język:"
    echo "  1. Polski"
    echo "  2. English"
    echo ""
    read -p "Choose / Wybierz [1-2]: " lang_choice

    case "$lang_choice" in
        2)
            LANG_CHOICE="en"
            echo ""
            echo "Selected: English"
            ;;
        *)
            LANG_CHOICE="pl"
            echo ""
            echo "Wybrano: Polski"
            ;;
    esac

    echo ""
    if [[ "$LANG_CHOICE" == "en" ]]; then
        echo "Enter default path for icons:"
        echo "  (this is where the script will look for icon files)"
        echo "  (ENTER for default: ${USER_HOME})"
    else
        echo "Podaj domyślną ścieżkę dla ikon:"
        echo "  (tu skrypt będzie szukał plików ikon)"
        echo "  (ENTER dla domyślnej: ${USER_HOME})"
    fi
    echo ""
    read -p "> " icon_path_input

    if [[ -n "$icon_path_input" ]]; then
        DEFAULT_ICON_PATH="$icon_path_input"
    fi

    # Zapisz config
    cat > "$CONFIG_FILE" << EOF
# webapp-gen config
LANG_CHOICE="$LANG_CHOICE"
DEFAULT_ICON_PATH="$DEFAULT_ICON_PATH"
EOF

    echo ""
    if [[ "$LANG_CHOICE" == "en" ]]; then
        echo "Configuration saved to: $CONFIG_FILE"
        echo "You can change it later with option 6 in menu."
    else
        echo "Konfiguracja zapisana w: $CONFIG_FILE"
        echo "Możesz ją zmienić później opcją 6 w menu."
    fi
    echo ""
    read -p "Press Enter to continue..."
}

create_default_config() {
    # Ta funkcja już niepotrzebna, ale zostawiam dla bezpieczeństwa
    cat > "$CONFIG_FILE" << EOF
# webapp-gen config
LANG_CHOICE="$LANG_CHOICE"
DEFAULT_ICON_PATH="$DEFAULT_ICON_PATH"
EOF
}


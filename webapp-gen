# ----------------
#          Sprawdza czy pkexec jest dostępne      /       Checks if pkexec is available
# -----------------
need_pkexec() {
    if ! command -v pkexec &>/dev/null; then
        echo " Brak pkexec (polkit). Zainstaluj: sudo pacman -S polkit"
        exit 1
    fi
}

# ----------------
#          Pyta o pojedynczą flagę chromium (helper)      /       Queries for a single chromium flag (helper)
# -----------------
ask_single_flag() {
    local key="$1"
    local default_yes="$2"
    local answer
    read -p "$(t "$key")" answer
    if [[ "$default_yes" == "yes" ]]; then
        [[ "$answer" =~ ^[Yy]$ ]] || [[ -z "$answer" ]]
    else
        [[ "$answer" =~ ^[Yy]$ ]]
    fi
}

# ----------------
#          Pyta o wszystkie flagi chromium      /       Queries for all chromium flags
# -----------------
ask_flags() {
    local flags=()
    echo "" >&2
    echo "$(t install_flags_title)" >&2
    echo "" >&2
    ask_single_flag "flag_translate" "yes" && flags+=("--disable-features=Translate,OptimizationGuide")
    ask_single_flag "flag_bg_net" "yes" && flags+=("--disable-background-networking")
    ask_single_flag "flag_extensions" "no" && flags+=("--disable-extensions")
    ask_single_flag "flag_sync" "no" && flags+=("--disable-sync")
    ask_single_flag "flag_gpu" "no" && flags+=("--disable-gpu")
    ask_single_flag "flag_incognito" "no" && flags+=("--incognito")
    ask_single_flag "flag_maximized" "no" && flags+=("--start-maximized")
    echo "${flags[@]}"
}

# ----------------
#          Obsługuje edycję custom flag w trybie ENTER/n/c      /       Supports editing custom flags in ENTER/n/c mode
# -----------------
handle_custom_flags_edit() {
    local current_flags="$1"
    local new_flags
    local action_choice

    if [[ -z "$current_flags" ]]; then
        printf "$(t custom_current)\n" "<brak / none>" >&2
    else
        printf "$(t custom_current)\n" "$current_flags" >&2
    fi

    read -p "$(t custom_action)" action_choice

    case "$action_choice" in
        "") # ENTER = zostaw
            new_flags="$current_flags"
            ;;
        n|N) # nowe
            read -p "$(t custom_new)" new_flags
            ;;
        c|C) # usuń
            new_flags=""
            echo "$(t custom_cleared)" >&2
            ;;
        *)
            new_flags="$current_flags"
            ;;
    esac

    # TYLKO to idzie na stdout -> do NEW_CUSTOM
    echo "$new_flags"
}

# ----------------
#          Rozwiązuje ścieżkę do ikony (absolutna lub z DEFAULT_ICON_PATH)      /       Resolves the icon path (absolute or from DEFAULT_ICON_PATH)
# -----------------
resolve_icon_path() {
    local input="$1"
    local base="$2"
    [[ -z "$input" ]] && return 1
    if [[ -f "$input" ]]; then echo "$input"; return 0; fi
    if [[ -f "${base}/${input}" ]]; then echo "${base}/${input}"; return 0; fi
    return 1
}

# ----------------
#          Kopiuje ikonę do magazynu ICON_DIR      /       Copies the icon to the ICON_DIR store
# -----------------
copy_icon_to_storage() {
    local src="$1"
    local app_name="$2"
    local ext="${src##*.}"
    local dest="${ICON_DIR}/${app_name}.${ext}"
    cp "$src" "$dest"
    echo "$dest"
}

# ----------------
#          Zapisuje wrapper, .desktop i config appki      /       Saves the app's wrapper, .desktop, and config
# -----------------
write_app_files() {
    local NAME="$1" URL="$2" ICON_LINE="$3" FLAGS="$4" CUSTOM_FLAGS="$5"
    local WRAPPER_PATH="${WRAPPER_DIR}/${NAME}-app"
    local CFG_PATH="${APPS_CONFIG_DIR}/${NAME}.cfg"
    local DESKTOP_FILE="${DESKTOP_DIR}/${NAME}.desktop"
    ensure_dirs
    cat > "$CFG_PATH" << EOF
NAME="${NAME}"
URL="${URL}"
ICON="${ICON_LINE}"
FLAGS="${FLAGS}"
CUSTOM_FLAGS="${CUSTOM_FLAGS}"
EOF
    cat > "$WRAPPER_PATH" << EOF
#!/bin/bash
source "${CFG_PATH}"
NAME="\${NAME:-\$NAZWA}"
chromium --class="\${NAME}" \${FLAGS} \${CUSTOM_FLAGS} --user-data-dir="${USER_HOME}/.config/\${NAME}-app" --app="\${URL}"
EOF
    chmod +x "$WRAPPER_PATH"
    tee "$DESKTOP_FILE" > /dev/null << EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=${NAME}
Comment=${NAME} webapp
Exec=${WRAPPER_PATH}
Icon=${ICON_LINE:-applications-internet}
Categories=Network;GTK;
Terminal=false
StartupNotify=true
StartupWMClass=${NAME}
EOF
    chmod +x "$DESKTOP_FILE"
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true
    echo ""
    printf "$(t install_done)\n" "$NAME"
}

# ----------------
#          Pobiera listę wszystkich appek do tablicy APPS      /       Fetches a list of all apps to the APPS array
# -----------------
get_all_apps() {
    APPS=()
    shopt -s nullglob
    for cfg in "$APPS_CONFIG_DIR"/*.cfg; do
        local app_name
        app_name=$(bash -c "source \"$cfg\"; echo \${NAME:-\$NAZWA}")
        [[ -n "$app_name" ]] && APPS+=("$app_name")
    done
    shopt -u nullglob
}

# ----------------
#          Zwraca nazwę appki po indeksie      /       Returns the app name by index
# -----------------
get_app_name_by_index() {
    local idx="$1"
    echo "${APPS[$((idx-1))]}"
}

# ----------------
#          Wyświetla szczegółowe info o jednej appce      /       Displays detailed information about a single app
# -----------------
show_app_info() {
    local NAME="$1"
    local CFG_PATH="${APPS_CONFIG_DIR}/${NAME}.cfg"
    # shellcheck source=/dev/null
    source "$CFG_PATH"
    local DISPLAY_NAME="${NAME:-$NAZWA}"
    local WRAPPER_PATH="${WRAPPER_DIR}/${DISPLAY_NAME}-app"
    local DESKTOP_FILE="${DESKTOP_DIR}/${DISPLAY_NAME}.desktop"

    printf "\n$(t separator_up)"
    printf "\n$(t detail_title)"
    printf "\n$(t separator_down)\n\n"
    printf "$(t detail_name)\n" "$DISPLAY_NAME"
    printf "$(t detail_url)\n" "$URL"
    printf "$(t detail_icon)\n" "${ICON:info_none}"
    printf "$(t detail_wrapper)\n" "$WRAPPER_PATH"
    printf "$(t detail_desktop)\n" "$DESKTOP_FILE"
    printf "$(t detail_config)\n" "$CFG_PATH"
    printf "$(t detail_flags)\n" "$FLAGS"
    printf "$(t detail_custom)\n" "${CUSTOM_FLAGS:info_none}"
    echo ""
}

show_app_details() {
    local NAME="$1"
    show_app_info "$NAME"
    echo ""
    echo "$(t detail_options)"
    echo ""
    echo "$(t detail_opt_edit)"
    echo "$(t detail_opt_remove)"
    echo "$(t detail_opt_back)"
    echo "$(t detail_opt_quit)"
    echo ""
}


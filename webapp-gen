# ----------------
#          Sprawdza czy pkexec jest dostępne
# -----------------
need_pkexec() {
    if ! command -v pkexec &>/dev/null; then
        echo "Brak pkexec (polkit). Zainstaluj: sudo pacman -S polkit"
        exit 1
    fi
}

# ----------------
#          Pyta o pojedynczą flagę chromium (helper)
# -----------------
ask_single_flag() {
    local prompt_en="$1"
    local prompt_pl="$2"
    local default_yes="$3"
    local prompt_text
    if [[ "$LANG_CHOICE" == "en" ]]; then prompt_text="$prompt_en"; else prompt_text="$prompt_pl"; fi
    local answer
    read -p "$prompt_text" answer
    if [[ "$default_yes" == "yes" ]]; then
        [[ "$answer" =~ ^[Yy]$ ]] || [[ -z "$answer" ]]
    else
        [[ "$answer" =~ ^[Yy]$ ]]
    fi
}

# ----------------
#          Pyta o wszystkie flagi chromium
# -----------------
ask_flags() {
    local flags=()
    echo "" >&2
    echo "$(t install_flags_title)" >&2
    echo "" >&2
    ask_single_flag "Disable Google Translate (--disable-features=Translate,OptimizationGuide) [Y/n]: " "Wyłącz tłumacz Google (--disable-features=Translate,OptimizationGuide) [Y/n]: " "yes" && flags+=("--disable-features=Translate,OptimizationGuide")
    ask_single_flag "Disable background networking (--disable-background-networking) [Y/n]: " "Wyłącz ruch w tle (--disable-background-networking) [Y/n]: " "yes" && flags+=("--disable-background-networking")
    ask_single_flag "Disable extensions (--disable-extensions) [y/N]: " "Wyłącz rozszerzenia (--disable-extensions) [y/N]: " "no" && flags+=("--disable-extensions")
    ask_single_flag "Disable sync (--disable-sync) [y/N]: " "Wyłącz synchronizację kont Google (--disable-sync) [y/N]: " "no" && flags+=("--disable-sync")
    ask_single_flag "Disable GPU (--disable-gpu) [y/N]: " "Wyłącz akcelerację GPU (--disable-gpu) [y/N]: " "no" && flags+=("--disable-gpu")
    ask_single_flag "Incognito (--incognito) [y/N]: " "Tryb incognito (--incognito) [y/N]: " "no" && flags+=("--incognito")
    ask_single_flag "Maximized (--start-maximized) [y/N]: " "Startuj zmaksymalizowane okno (--start-maximized) [y/N]: " "no" && flags+=("--start-maximized")
    echo "${flags[@]}"
}

# ----------------
#          Obsługuje edycję custom flag w trybie ENTER/n/c
# -----------------
handle_custom_flags_edit() {
    local current_flags="$1"
    local new_flags
    local action_choice

    if [[ -z "$current_flags" ]]; then
        printf "$(t custom_current)\n" "<brak / none>" >&2
    else
        printf "$(t custom_current)\n" "$current_flags" >&2
    fi

    read -p "$(t custom_action)" action_choice

    case "$action_choice" in
        "") # ENTER = zostaw
            new_flags="$current_flags"
            ;;
        n|N) # nowe
            read -p "$(t custom_new)" new_flags
            ;;
        c|C) # usuń
            new_flags=""
            echo "$(t custom_cleared)" >&2
            ;;
        *)
            new_flags="$current_flags"
            ;;
    esac

    # TYLKO to idzie na stdout -> do NEW_CUSTOM
    echo "$new_flags"
}

# ----------------
#          Rozwiązuje ścieżkę do ikony (absolutna lub z DEFAULT_ICON_PATH)
# -----------------
resolve_icon_path() {
    local input="$1"
    local base="$2"
    [[ -z "$input" ]] && return 1
    if [[ -f "$input" ]]; then echo "$input"; return 0; fi
    if [[ -f "${base}/${input}" ]]; then echo "${base}/${input}"; return 0; fi
    return 1
}

# ----------------
#          Kopiuje ikonę do magazynu ICON_DIR
# -----------------
copy_icon_to_storage() {
    local src="$1"
    local app_name="$2"
    local ext="${src##*.}"
    local dest="${ICON_DIR}/${app_name}.${ext}"
    cp "$src" "$dest"
    echo "$dest"
}

# ----------------
#          Zapisuje wrapper, .desktop i config appki
# -----------------
write_app_files() {
    local NAME="$1" URL="$2" ICON_LINE="$3" FLAGS="$4" CUSTOM_FLAGS="$5"
    local WRAPPER_PATH="${WRAPPER_DIR}/${NAME}-app"
    local CFG_PATH="${APPS_CONFIG_DIR}/${NAME}.cfg"
    local DESKTOP_FILE="${DESKTOP_DIR}/${NAME}.desktop"
    ensure_dirs
    cat > "$CFG_PATH" << EOF
NAME="${NAME}"
URL="${URL}"
ICON="${ICON_LINE}"
FLAGS="${FLAGS}"
CUSTOM_FLAGS="${CUSTOM_FLAGS}"
EOF
    cat > "$WRAPPER_PATH" << EOF
#!/bin/bash
source "${CFG_PATH}"
NAME="\${NAME:-\$NAZWA}"
chromium --class="\${NAME}" \${FLAGS} \${CUSTOM_FLAGS} --user-data-dir="${USER_HOME}/.config/\${NAME}-app" --app="\${URL}"
EOF
    chmod +x "$WRAPPER_PATH"
    tee "$DESKTOP_FILE" > /dev/null << EOF
[Desktop Entry]
Version=1.0
Type=Application
Name=${NAME}
Comment=${NAME} webapp
Exec=${WRAPPER_PATH}
Icon=${ICON_LINE:-applications-internet}
Categories=Network;GTK;
Terminal=false
StartupNotify=true
StartupWMClass=${NAME}
EOF
    chmod +x "$DESKTOP_FILE"
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true
    echo ""
    printf "$(t install_done)\n" "$NAME"
}

# ----------------
#          Pobiera listę wszystkich appek do tablicy APPS
# -----------------
get_all_apps() {
    APPS=()
    shopt -s nullglob
    for cfg in "$APPS_CONFIG_DIR"/*.cfg; do
        local app_name
        app_name=$(bash -c "source \"$cfg\"; echo \${NAME:-\$NAZWA}")
        [[ -n "$app_name" ]] && APPS+=("$app_name")
    done
    shopt -u nullglob
}

# ----------------
#          Zwraca nazwę appki po indeksie
# -----------------
get_app_name_by_index() {
    local idx="$1"
    echo "${APPS[$((idx-1))]}"
}

# ----------------
#          Wyświetla szczegółowe info o jednej appce
# -----------------
show_app_details() {
    local NAME="$1"
    local CFG_PATH="${APPS_CONFIG_DIR}/${NAME}.cfg"
    # shellcheck source=/dev/null
    source "$CFG_PATH"
    local DISPLAY_NAME="${NAME:-$NAZWA}"
    local WRAPPER_PATH="${WRAPPER_DIR}/${DISPLAY_NAME}-app"
    local DESKTOP_FILE="${DESKTOP_DIR}/${DISPLAY_NAME}.desktop"

    echo ""
    printf "$(t detail_title)\n\n"
    printf "$(t detail_name)\n" "$DISPLAY_NAME"
    printf "$(t detail_url)\n" "$URL"
    printf "$(t detail_icon)\n" "${ICON:info_none}"
    printf "$(t detail_wrapper)\n" "$WRAPPER_PATH"
    printf "$(t detail_desktop)\n" "$DESKTOP_FILE"
    printf "$(t detail_config)\n" "$CFG_PATH"
    printf "$(t detail_flags)\n" "$FLAGS"
    printf "$(t detail_custom)\n" "${CUSTOM_FLAGS:info_none}"
    echo ""
    echo "$(t detail_options)"
    echo ""
    echo "$(t detail_opt_edit)"
    echo "$(t detail_opt_remove)"
    echo "$(t detail_opt_back)"
    echo "$(t detail_opt_quit)"
    echo ""
}

# ----------------
#          Edytuje konkretną apkę podaną z nazwy (używane z widoku szczegółów)
# -----------------
edit_app_direct() {
    local NAME="$1"
    local CFG="${APPS_CONFIG_DIR}/${NAME}.cfg"
    # shellcheck source=/dev/null
    source "$CFG"
    NAME="${NAME:-$NAZWA}"

    local NEW_URL
    printf "$(t edit_current_url)\n" "$URL"
    read -p "$(t edit_new_url)" NEW_URL
    [[ -z "$NEW_URL" ]] && NEW_URL="$URL"

    printf "$(t edit_current_flags)\n" "$FLAGS"
    local NEW_FLAGS
    NEW_FLAGS=$(ask_flags)

    # NOWA LOGIKA: ENTER=zostaw / n=nowe / c=usuń
    local NEW_CUSTOM
    NEW_CUSTOM=$(handle_custom_flags_edit "$CUSTOM_FLAGS")

    if [[ "$LANG_CHOICE" == "en" ]]; then
        echo "New icon file (ENTER = keep current):"
    else
        echo "Nowy plik ikony (ENTER = zostaw obecną):"
    fi
    local ICON_INPUT ICON_PATH
    read -p "> " ICON_INPUT

    local ICON_LINE="$ICON"
    if ICON_PATH=$(resolve_icon_path "$ICON_INPUT" "$DEFAULT_ICON_PATH"); then
        ICON_LINE=$(copy_icon_to_storage "$ICON_PATH" "$NAME")
        printf "$(t edit_icon_updated)\n" "$ICON_LINE"
    fi

    write_app_files "$NAME" "$NEW_URL" "$ICON_LINE" "$NEW_FLAGS" "$NEW_CUSTOM"
}

# ----------------
#          Usuwa konkretną apkę podaną z nazwy (z potwierdzeniem)
# -----------------
remove_app_direct() {
    local NAME="$1"
    local confirm
    read -p "$(printf "$(t remove_confirm)" "$NAME")" confirm
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        return 1
    fi
    rm -f "${WRAPPER_DIR}/${NAME}-app" "${APPS_CONFIG_DIR}/${NAME}.cfg" "${DESKTOP_DIR}/${NAME}.desktop" "${ICON_DIR}/${NAME}".*
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true
    printf "$(t remove_done)\n" "$NAME"
    return 0
}

# ----------------
#          Instaluje nową apkę - pyta o nazwę, URL, flagi i ikonę
# -----------------
cmd_install() {
    printf "\n$(t install_title)\n\n"
    local NAME URL FLAGS CUSTOM_FLAGS ICON_INPUT ICON_PATH ICON_LINE
    read -p "$(t install_name)" NAME
    NAME=$(echo "$NAME" | tr -d ' ')
    if [[ -z "$NAME" ]]; then echo "$(t install_name_error)"; return 1; fi
    if [[ ! "$NAME" =~ ^[a-zA-Z0-9_-]+$ ]]; then echo "Błąd: tylko litery, cyfry, _ i -"; return 1; fi
    if [[ -f "${APPS_CONFIG_DIR}/${NAME}.cfg" ]] || [[ -f "${WRAPPER_DIR}/${NAME}-app" ]]; then printf "$(t install_exists)\n" "$NAME"; return 1; fi
    read -p "$(t install_url)" URL
    if [[ -z "$URL" ]]; then echo "$(t install_url_error)"; return 1; fi
    FLAGS=$(ask_flags)
    printf "\n$(t install_flags_choice)\n" "$FLAGS"
    read -p "Dodatkowe własne flagi [ENTER=brak]: " CUSTOM_FLAGS
    echo ""
    if [[ "$LANG_CHOICE" == "en" ]]; then echo "Enter icon filename from folder."; else echo "Podaj nazwe pliku ikony z wybranego folderu."; fi
    read -p "$DEFAULT_ICON_PATH: " ICON_INPUT
    ICON_LINE=""
    if ICON_PATH=$(resolve_icon_path "$ICON_INPUT" "$DEFAULT_ICON_PATH"); then
        ICON_LINE=$(copy_icon_to_storage "$ICON_PATH" "$NAME")
        printf "$(t install_icon_copied)\n" "$ICON_LINE"
    fi
    write_app_files "$NAME" "$URL" "$ICON_LINE" "$FLAGS" "$CUSTOM_FLAGS"
}

# ----------------
#          Nowe: Lista z widokiem szczegółów i akcjami e/r/p/q
# -----------------
cmd_list() {
    while true; do
        get_all_apps
        if [[ ${#APPS[@]} -eq 0 ]]; then
            echo ""
            echo "$(t list_empty)"
            return 0
        fi

        echo ""
        printf "$(t list_title)\n\n"
        local i=1
        for app_name in "${APPS[@]}"; do
            echo " $i. $app_name"
            ((i++))
        done
        echo ""
        printf "\n$(t key_p)"
        printf "\n$(t key_q)\n"
        echo ""

        local sel
        read -p "$(t list_select_prompt)" sel

        # powrót do menu głównego
        if [[ "$sel" == "p" ]] || [[ "$sel" == "P" ]]; then
            return 0
        fi
        if [[ "$sel" == "q" ]] || [[ "$sel" == "Q" ]]; then
            echo "$(t goodbye)"
            exit 0
        fi

        if [[ ! "$sel" =~ ^[0-9]+$ ]] || (( sel < 1 || sel > ${#APPS[@]} )); then
            echo "$(t edit_invalid)"
            sleep 1
            continue
        fi

        local SELECTED
        SELECTED=$(get_app_name_by_index "$sel")

        # pętla szczegółów wybranej appki
        while true; do
            clear
            show_app_details "$SELECTED"

            local action
            read -n 1 -p "$(t detail_prompt)" action
            echo ""

            case "$action" in
                e|E)
                    echo ""
                    edit_app_direct "$SELECTED"
                    echo ""
                    read -n 1 -p "$(t press_enter)" _
                    ;;
                r|R)
                    echo ""
                    if remove_app_direct "$SELECTED"; then
                        sleep 1
                        break # usuń -> wróć do listy
                    fi
                    ;;
                p|P)
                    break # powrót do listy
                    ;;
                q|Q)
                    echo "$(t goodbye)"
                    exit 0
                    ;;
                *)
                    echo "$(t menu_invalid)"
                    sleep 1
                    ;;
            esac
        done
    done
}

# ----------------
#          Edytuje globalną konfigurację - język i ścieżkę ikon
# -----------------
cmd_config() {
    printf "\n$(t config_title)\n\n"
    local new_lang new_path
    read -p "$(printf "$(t config_lang)" "$LANG_CHOICE")" new_lang
    [[ -n "$new_lang" ]] && LANG_CHOICE="$new_lang"
    read -p "$(printf "$(t config_icon_path)" "$DEFAULT_ICON_PATH")" new_path
    [[ -n "$new_path" ]] && DEFAULT_ICON_PATH="$new_path"
    save_config
    echo "$(t config_done)"
}

# ----------------
#          Wyświetla główne menu 1-4 i obsługuje wybór
# -----------------
main_menu() {
    clear
    printf "\n$(t menu_title)"
    printf "\n$(t version_title)\n\n"
    echo "$(t menu_install)"
    echo "$(t menu_list)"
    echo "$(t menu_config)"
    echo "$(t menu_exit)"
    echo ""
    local choice
    read -n 1 -p "$(t menu_prompt)" choice
    echo ""
    if [[ "$choice" == "q" ]] || [[ "$choice" == "Q" ]]; then
        echo "$(t goodbye)"
        exit 0
    fi
    case "$choice" in
        1) cmd_install ;;
        2) cmd_list ;;
        3) cmd_config ;;
        4) echo "$(t goodbye)"; exit 0 ;;
        *) echo "$(t menu_invalid)"; sleep 1 ;;
    esac
}

# ----------------
#          Główna pętla interaktywna
# -----------------
main_loop() {
    while true; do
        main_menu
        echo ""
        local input
        read -n 1 -p "$(t press_enter)" input
        echo ""
        if [[ "$input" == "q" ]] || [[ "$input" == "Q" ]]; then
            echo "$(t goodbye)"
            exit 0
        fi
    done
}

# ----------------
#          Obsługuje argumenty CLI
# -----------------
handle_cli_args() {
    case "$1" in
        -list) cmd_list ;;
        -remove)
            get_all_apps
            [[ ${#APPS[@]} -eq 0 ]] && echo "$(t list_empty)" && return
            for i in "${!APPS[@]}"; do echo " $((i+1)). ${APPS[$i]}"; done
            read -p "$(t list_select_prompt)" sel
            if [[ "$sel" =~ ^[0-9]+$ ]]; then
                local n; n=$(get_app_name_by_index "$sel")
                [[ -n "$n" ]] && remove_app_direct "$n"
            fi
            ;;
        -edit)
            get_all_apps
            [[ ${#APPS[@]} -eq 0 ]] && echo "$(t list_empty)" && return
            for i in "${!APPS[@]}"; do echo " $((i+1)). ${APPS[$i]}"; done
            read -p "$(t list_select_prompt)" sel
            if [[ "$sel" =~ ^[0-9]+$ ]]; then
                local n; n=$(get_app_name_by_index "$sel")
                [[ -n "$n" ]] && edit_app_direct "$n"
            fi
            ;;
        -config) cmd_config ;;
        -h|--help|help)
            echo "Użycie:"
            echo "  webapp-gen              -> interaktywne menu (1-4)"
            echo "  webapp-gen -list        -> lista + szczegóły e/r/p/q"
            echo "  webapp-gen -edit        -> edytuj appkę"
            echo "  webapp-gen -remove      -> usuń appkę"
            echo "  webapp-gen -config      -> konfiguracja"
            ;;
        "") main_loop ;;
        *) echo "Nieznana opcja: $1"; echo "Użyj 'webapp-gen -h' dla pomocy."; exit 1 ;;
    esac
}

# ----------------
#          Punkt wejścia programu
# -----------------
main() {
    init_globals
    ensure_dirs
    load_lang
    handle_cli_args "$@"
}

main "$@"

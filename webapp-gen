#!/bin/bash
# webapp-gen — web app generator (chromium --app)
set -e

# ----------------
#          Inicjalizuje globalne ścieżki i zmienne      /       Initializes global paths and variables
# -----------------
init_globals() {
    USER_HOME="$HOME"
    WRAPPER_DIR="${USER_HOME}/.local/bin/webapp-list"
    DESKTOP_DIR="${USER_HOME}/.local/share/applications"
    ICON_DIR="${USER_HOME}/.local/share/icons/webapp-ico"
    CONFIG_DIR="${USER_HOME}/.config/webapp-gen"
    CONFIG_FILE="${CONFIG_DIR}/config.cfg"
    APPS_CONFIG_DIR="${CONFIG_DIR}/apps"
    VER="1.1"
    VERSION="v${VER}"
    VERSION_PLUS="+ + + ${VERSION}"

    # --- Update ---
    REPO_OWNER="KamiLulek"
    REPO_NAME="Webapp-gen"
    REPO_BRANCH="main"
    REPO_RAW_URL="https://raw.githubusercontent.com/${REPO_OWNER}/${REPO_NAME}/${REPO_BRANCH}/webapp-gen"
    UPDATE_CACHE_FILE="${CONFIG_DIR}/.last_update_check"
    UPDATE_CHECK_INTERVAL=86400   # 24h, żeby nie odpytywać githuba za każdym uruchomieniem
}

# ----------------
#          Tworzy wszystkie wymagane katalogi      /       Creates all required directories
# -----------------
ensure_dirs() {
    mkdir -p "$CONFIG_DIR" "$APPS_CONFIG_DIR" "$WRAPPER_DIR" "$DESKTOP_DIR" "$ICON_DIR"
}

# ----------------
#          Ładuje język i config, jeśli brak to odpala first_time_config      /       Loads the language and config; if missing, runs first_time_config
# -----------------
load_lang() {
    LANG_CHOICE="pl"
    DEFAULT_ICON_PATH="${USER_HOME}/Obrazy"
    ensure_dirs
    if [[ -f "$CONFIG_FILE" ]]; then
        # shellcheck source=/dev/null
        source "$CONFIG_FILE"
    else
        first_time_config
    fi
}

# ----------------
#          Pierwsze uruchomienie - wybór języka i domyślnej ścieżki ikon      /       First run - selects the language and default icon path
# -----------------
first_time_config() {
    clear
    echo ""
    printf "\n$(t separator_up)"
    printf "\n$(t menu_title)""- FIRST RUN "
    printf "\n$(t separator_down)\n\n"
    echo ""
    echo " Select language / Wybierz język:"
    echo "  1. Polski"
    echo "  2. English"
    echo ""
    read -p " Choose / Wybierz [1-2]: " lang_choice
    case "$lang_choice" in
        2) LANG_CHOICE="en"; echo ""; echo " Selected: English" ;;
        *) LANG_CHOICE="pl"; echo ""; echo " Wybrano: Polski" ;;
    esac
    echo ""
    echo "$(t first_run_icon_path_prompt)"
    printf "$(t first_run_icon_path_hint)\n" "$USER_HOME"
    read -p "$(t first_run_icon_path_set)" icon_path_input
    [[ -n "$icon_path_input" ]] && DEFAULT_ICON_PATH="$icon_path_input"
    save_config
    echo ""
    printf "$(t first_run_config_saved)\n" "$CONFIG_FILE"
    echo ""
    read -p " Press Enter to continue..."
}

# ----------------
#          Zapisuje aktualną konfigurację do pliku      /        Saves the current configuration to a file
# -----------------
save_config() {
    cat > "$CONFIG_FILE" << EOF
# webapp-gen config
LANG_CHOICE="$LANG_CHOICE"
DEFAULT_ICON_PATH="$DEFAULT_ICON_PATH"
EOF
}

